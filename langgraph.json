{
  "dependencies": [
    "."
  ],
  "graphs": {
    "test_case_agent": "./src/agent/app.py:graph"
  },
  "env": ".env",
  "http": {
    "cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["*"]
    }
  },
  "auth": {
    "path": "./src/agent/auth.py:auth",
    "disable_for_testing": true
  },
  "watch": {
    "exclude": ["scripts/**"]
  }
}